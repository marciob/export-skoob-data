# Copy this file to ".env" and fill in your token.
#
# Your Skoob API token (a JWT). See README.md -> "Getting your Skoob token".
# It is sent as the Authorization header. Expires ~15 days after issue,
# so you will need to refresh it periodically.
SKOOB_JWT=

# Optional. Leave blank — it is read automatically from the token.
# Only set this if you want to export a different (public) profile:
# it's the id in the profile URL https://www.skoob.com.br/.../user/{id}/bookshelf
SKOOB_USER_ID=
